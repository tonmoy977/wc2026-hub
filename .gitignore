# ============================================
# PROTECTION: Ignore everything by default
# ============================================
*

# ============================================
# ALLOW: GitHub Actions to work
# ============================================
!.gitignore
!index.html
!scrape.js
!data/
!data/live.json
!.github/
!.github/workflows/
!.github/workflows/*.yml

# ============================================
# PROTECTION: Lock critical files
# ============================================
index.html merge=ours
scrape.js merge=ours

# ============================================
# IGNORE: Mobile/browser temp files
# ============================================
*.tmp
*.bak
*.swp
*.swo
*~
.DS_Store
Thumbs.db
